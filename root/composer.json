{
	"name": "{%= composer_package_name %}",
	"description": "{%= description %}",
	"type": "wordpress-theme",
	"license": "MIT",
	"authors": [
		{
			"name": "{%= author_name %}",
			"email": "{%= author_email %}"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"pressgang-wp/pressgang": "dev-master",
		"pressgang-wp/pressgang-snippets": "dev-main",
		"pressgang-wp/quartermaster": "dev-main"
	},
	"extra": {
		"installer-paths": {
			"../../plugins/{$name}/": [
				"type:wordpress-plugin"
			],
			"../../themes/{$name}/": [
				"type:wordpress-theme"
			]
		}
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true,
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"autoload": {
		"psr-4": {
			"{%= namespace_json %}": "src/"
		}
	}
}
